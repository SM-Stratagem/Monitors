# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/hantavirus_monitor

# Security
CRON_SECRET=your-random-secret-key-here

# AI Integration (Google Gemini)
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-3.1-flash-lite
INGEST_AI_ENABLED=true
INGEST_AI_MAX=5
INGEST_GEMINI_TIMEOUT_MS=14000

# News API (optional, adds more signal sources)
NEWS_API_KEY=your-newsapi-org-key
SERP_API_KEY=your-serpapi-key

# Flight tracking (optional)
OPENSKY_API_KEY=your-opensky-key

# Public Configuration
NEXT_PUBLIC_BUYMECOFFEE_URL=https://buymeacoffee.com/your-username
NEXT_PUBLIC_SITE_URL=https://your-deployment-url.com

# Google AdSense (optional)
NEXT_PUBLIC_ADSENSE_CLIENT=your-adsense-client-id
NEXT_PUBLIC_ADSENSE_SLOT_TOP=your-adsense-slot-id

# Ingestion reliability (optional)
INGEST_HTTP_TIMEOUT_MS=12000
INGEST_KEEP_DAYS=30

# Cost control: avoid ingestion on user traffic (recommended when Railway cron is enabled)
DASHBOARD_AUTO_INGEST_ENABLED=false
DASHBOARD_AUTO_INGEST_STALE_HOURS=12

# Pipeline reliability (optional)
INGEST_MAX_RETRIES=3
INGEST_CIRCUIT_BREAKER_THRESHOLD=3
INGEST_CIRCUIT_BREAKER_COOLDOWN_MS=1800000
INGEST_JOB_TIMEOUT_MS=300000
INGEST_BATCH_SIZE=50
INGEST_AI_CONCURRENCY=3
