{
  "name": "ebola-monitor",
  "version": "1.0.0",
  "description": "Real-time Ebola virus disease (EVD) monitoring dashboard with scheduled ingestion and Railway deployment",
  "private": true,
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "postbuild": "node scripts/prepare-standalone.mjs",
    "start": "next start",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx db/migrate.ts",
    "ingest:once": "tsx src/lib/run-ingest.ts"
  },
  "keywords": [
    "ebola",
    "evd",
    "ebola-virus-disease",
    "outbreak-tracker",
    "nextjs",
    "railway",
    "monitoring"
  ],
  "author": "Suhayl",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@google/genai": "^2.0.1",
    "@types/leaflet": "^1.9.21",
    "cheerio": "^1.2.0",
    "clsx": "^2.1.1",
    "d3-geo": "^3.1.1",
    "dayjs": "^1.11.20",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "leaflet": "^1.9.4",
    "next": "^16.2.6",
    "pg": "^8.20.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "rss-parser": "^3.13.0",
    "topojson-client": "^3.1.0",
    "tsx": "^4.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/d3-geo": "^3.1.0",
    "@types/node": "^25.6.2",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/topojson-client": "^3.1.5",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.6",
    "playwright": "^1.59.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
